.DS_Store
online/cwo*
online/project/*
online/target/*
solo/game-error*
solo/project/project/*
solo/project/target/*
solo/target/*
solo/images/*
solo/info/*
solo/fonts/*
# 2026-05-29 user direction: track MNU's webp image assets in the repo
# (the directory used to be gitignored entirely). Only the dev artifacts
# inside webp/ stay excluded:
#   - solo/webp/main.js + main.js.map — stray copies of the compiled bundle.
#   - solo/webp/browser-test.html — local dev harness page.
#   - **/*.orig — sed/edit backups.
solo/webp/main.js
solo/webp/main.js.map
solo/webp/browser-test.html
solo/webp/**/*.orig
solo/web.config

# User direction 2026-05-22: sim/ tooling is NOT part of the live build and
# should not be tracked by the repo at all. Live deploys only copy
# main.js, index.html, webp/, fonts/.
sim/

# 2026-05-22: scripts/ holds local dev tooling (publish/deploy helpers).
# Any inline secrets must live in ~/.config/cwo/ (outside the repo).
# Keeping scripts/ untracked entirely is the safest default — if a script
# needs to be in the repo, add a per-file negation below.
scripts/

# macOS finder metadata
**/.DS_Store