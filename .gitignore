.DS_Store
online/cwo*
online/project/*
online/target/*
solo/game-error*
solo/project/project/*
solo/project/target/*
solo/target/*
solo/images/*
solo/info/*
solo/fonts/*
solo/webp/*
solo/web.config

# User direction 2026-05-22: sim/ tooling is NOT part of the live build and
# should not be tracked by the repo at all. Live builds (publish-pages.sh
# and deploy-mnu-to-vm.sh) only copy main.js, index.html, webp/, fonts/ —
# sim/ was never deployed. This rule keeps the sim source on the dev
# working tree without committing it.
sim/

# 2026-05-22: scripts/ holds local dev tooling (publish-pages.sh + helpers).
# publish-pages.sh used to inline a GitHub PAT in the remote URL; PAT now
# lives in ~/.config/cwo/github-pat (outside the repo). Keeping scripts/
# untracked entirely is the safest default — if a script needs to be in
# the repo, add a per-file negation below.
scripts/

# macOS finder metadata
**/.DS_Store